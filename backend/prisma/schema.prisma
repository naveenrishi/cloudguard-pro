generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String?
  role              Role      @default(USER)
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  cloudAccounts            CloudAccount[]
  nukeRetentions           NukeRetention[]
  nukeRuns                 NukeRun[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  sessions                 Session[]
  verificationTokens       VerificationToken[]
  mfaBackupCodes           MfaBackupCode[]
  billingSchedules         BillingSchedule[]
  automationLogs           AutomationLog[]
  migrationRecommendations MigrationRecommendation[]
  serviceNowConfigs        ServiceNowConfig[]
  alerts                   Alert[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  VIEWER
}

// ============================================
// AUTH
// ============================================

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  token     String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([token])
  @@map("verification_tokens")
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  MFA_SETUP
}

model MfaBackupCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_backup_codes")
}

// ============================================
// CLOUD ACCOUNTS
// ============================================

model CloudAccount {
  id          String        @id @default(cuid())
  userId      String
  provider    CloudProvider
  accountName String
  accountId   String
  region      String?
  credentials String?       @db.Text
  status      AccountStatus @default(ACTIVE)
  lastSyncAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources        Resource[]
  costData         CostData[]
  securityFindings SecurityFinding[]
  nukeConfig       NukeConfig?
  nukeRetentions   NukeRetention[]
  costAnomalies    CostAnomaly[]
  incidents        Incident[]
  changeEvents     ChangeEvent[]
  alerts           Alert[]

  @@unique([userId, provider, accountId])
  @@map("cloud_accounts")
}

enum CloudProvider {
  AWS
  AZURE
  GCP
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

// ============================================
// RESOURCES
// ============================================

model Resource {
  id           String   @id @default(cuid())
  accountId    String
  resourceId   String
  resourceType String
  resourceName String
  region       String
  metadata     String   @db.Text
  status       String
  tags         String?  @db.Text
  costPerMonth Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      CloudAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metrics      ResourceMetric[]

  @@unique([accountId, resourceId])
  @@index([accountId, resourceType])
  @@index([resourceType])
  @@map("resources")
}

model ResourceMetric {
  id          String   @id @default(cuid())
  resourceId  String
  metricName  String
  metricValue Float
  unit        String
  timestamp   DateTime
  createdAt   DateTime @default(now())

  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, metricName, timestamp])
  @@map("resource_metrics")
}

// ============================================
// COST DATA
// ============================================

model CostData {
  id        String   @id @default(cuid())
  accountId String
  date      DateTime
  service   String
  cost      Float
  currency  String   @default("USD")
  usage     Float?
  usageUnit String?
  region    String?
  createdAt DateTime @default(now())

  account   CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date, service, region])
  @@index([accountId, date])
  @@map("cost_data")
}

// ============================================
// SECURITY FINDINGS
// ============================================

model SecurityFinding {
  id               String        @id @default(cuid())
  accountId        String
  findingId        String
  severity         Severity
  title            String
  description      String        @db.Text
  resourceType     String
  resourceId       String?
  region           String?
  status           FindingStatus @default(ACTIVE)
  remediationSteps String?       @db.Text
  detectedAt       DateTime
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  account          CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, findingId])
  @@index([accountId, severity, status])
  @@map("security_findings")
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  ACTIVE
  RESOLVED
  SUPPRESSED
  IN_PROGRESS
}

// ============================================
// OPTIMIZATION RECOMMENDATIONS
// ============================================

model Recommendation {
  id                  String                 @id @default(cuid())
  accountId           String?
  resourceId          String?
  category            RecommendationCategory
  title               String
  description         String                 @db.Text
  impact              Impact
  savings             Float?
  effort              Effort
  status              RecommendationStatus   @default(OPEN)
  implementationSteps String?                @db.Text
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([accountId, status, impact])
  @@map("recommendations")
}

enum RecommendationCategory {
  COST
  PERFORMANCE
  SECURITY
  RELIABILITY
  SUSTAINABILITY
}

enum Impact {
  HIGH
  MEDIUM
  LOW
}

enum Effort {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

// ============================================
// NUKE AUTOMATION
// ============================================

model NukeConfig {
  id                 String    @id @default(cuid())
  accountId          String    @unique
  mode               NukeMode  @default(AUTOMATIC)
  enabled            Boolean   @default(true)
  scheduleLabel      String?
  nextRunAt          DateTime?
  notificationDays   Int       @default(7)
  notificationEmails String    @default("[]") @db.Text
  nukeCode           String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  account            CloudAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  nukeRuns           NukeRun[]
  nukeNotifications  NukeNotification[]

  @@map("nuke_configs")
}

enum NukeMode {
  AUTOMATIC
  MANUAL
}

model NukeRetention {
  id              String          @id @default(cuid())
  accountId       String
  userId          String
  cloudResourceId String
  resourceType    String
  resourceName    String
  resourceRegion  String?
  resourceMeta    String?         @db.Text
  retentionType   RetentionType
  expiresAt       DateTime?
  retainDays      Int?
  reason          String          @db.Text
  status          RetentionStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  account         CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([cloudResourceId])
  @@map("nuke_retentions")
}

enum RetentionType {
  PERMANENT
  UNTIL_DATE
  DAYS
}

enum RetentionStatus {
  ACTIVE
  EXPIRED
  REMOVED
}

model NukeRun {
  id                String    @id @default(cuid())
  configId          String
  userId            String
  runType           RunType
  status            RunStatus @default(PENDING)
  totalResources    Int       @default(0)
  deletedResources  Int       @default(0)
  retainedResources Int       @default(0)
  failedResources   Int       @default(0)
  skippedResources  Int       @default(0)
  wouldDelete       Int       @default(0)
  dryRunReport      String?   @db.Text
  skippedDetails    String?   @db.Text
  errorMessage      String?   @db.Text
  triggeredBy       String?
  startedAt         DateTime?
  completedAt       DateTime?
  duration          String?
  createdAt         DateTime  @default(now())

  config            NukeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([configId, createdAt])
  @@map("nuke_runs")
}

enum RunType {
  DRY_RUN
  LIVE
  SCHEDULED
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model NukeNotification {
  id              String     @id @default(cuid())
  configId        String
  recipientEmails String     @db.Text
  subject         String
  daysUntilNuke   Int
  status          String     @default("sent")
  sentAt          DateTime   @default(now())

  config          NukeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@map("nuke_notifications")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  priority  Priority         @default(NORMAL)
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  String?          @db.Text
  createdAt DateTime         @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

enum NotificationType {
  COST_ALERT
  SECURITY_ALERT
  NUKE_SCHEDULED
  NUKE_COMPLETED
  RETENTION_APPROVED
  RETENTION_REJECTED
  SYNC_COMPLETED
  SYNC_FAILED
  ACCOUNT_CONNECTED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  entityType   String
  entityId     String?
  changes      String?  @db.Text
  ipAddress    String?
  userAgent    String?
  status       String
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  user         User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================
// MIGRATION DATA
// ============================================

model MigrationAnalysis {
  id              String        @id @default(cuid())
  sourceAccountId String?
  targetProvider  CloudProvider
  workloadType    String
  currentCost     Float
  targetCost      Float
  savingsPercent  Float
  complexity      String
  timeline        String
  recommendations String        @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("migration_analyses")
}

model MigrationRecommendation {
  id             String                        @id @default(cuid())
  userId         String
  cloudAccountId String?
  resourceId     String?
  provider       CloudProvider?
  title          String
  description    String                        @db.Text
  targetCloud    CloudProvider?
  savings        Float?
  complexity     String?
  status         MigrationRecommendationStatus @default(PENDING)
  metadata       String?                       @db.Text
  dismissedAt    DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("migration_recommendations")
}

enum MigrationRecommendationStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

// ============================================
// BUDGETS
// ============================================

model Budget {
  id             String       @id @default(cuid())
  accountId      String?
  name           String
  amount         Float
  period         BudgetPeriod
  startDate      DateTime
  endDate        DateTime?
  alertThreshold Float        @default(80)
  notifyOnExceed Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([accountId])
  @@map("budgets")
}

enum BudgetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ============================================
// BILLING SCHEDULES
// ============================================

model BillingSchedule {
  id         String              @id @default(cuid())
  userId     String
  name       String
  frequency  BillingFrequency
  format     BillingExportFormat
  recipients String              @db.Text
  sections   String              @db.Text
  active     Boolean             @default(true)
  lastSentAt DateTime?
  nextSendAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active, nextSendAt])
  @@map("billing_schedules")
}

enum BillingFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum BillingExportFormat {
  CSV
  PDF
}

// ============================================
// AUTOMATION LOGS
// ============================================

model AutomationLog {
  id           String           @id @default(cuid())
  userId       String
  accountId    String?
  provider     CloudProvider?
  action       String
  resourceType String?
  resourceId   String?
  region       String?
  dryRun       Boolean          @default(false)
  status       AutomationStatus
  result       String?          @db.Text
  errorMessage String?          @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  duration     Int?
  createdAt    DateTime         @default(now())

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([accountId, action])
  @@map("automation_logs")
}

enum AutomationStatus {
  SUCCESS
  FAILED
  DRY_RUN
  PENDING
}

// ============================================
// ANALYTICS — COST ANOMALIES
// ============================================

model CostAnomaly {
  id           String          @id @default(cuid())
  accountId    String
  service      String
  anomalyType  AnomalyType
  severity     AnomalySeverity
  title        String
  description  String          @db.Text
  expectedCost Float
  actualCost   Float
  variance     Float
  detectedAt   DateTime
  resolvedAt   DateTime?
  status       AnomalyStatus   @default(OPEN)
  metadata     String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  account      CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status, detectedAt])
  @@index([severity, status])
  @@map("cost_anomalies")
}

enum AnomalyType {
  SPIKE
  FORECAST_OVERAGE
  CONCENTRATION_RISK
  UNUSED_RESOURCE
  RESERVATION_EXPIRY
}

enum AnomalySeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AnomalyStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  FALSE_POSITIVE
}

// ============================================
// ANALYTICS — INCIDENTS
// ============================================

model Incident {
  id          String         @id @default(cuid())
  accountId   String
  title       String
  description String         @db.Text
  severity    Severity
  status      IncidentStatus @default(OPEN)
  source      String
  resourceId  String?
  region      String?
  detectedAt  DateTime
  resolvedAt  DateTime?
  resolvedBy  String?
  metadata    String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  account     CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status, severity])
  @@index([detectedAt])
  @@map("incidents")
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATING
  RESOLVED
  CLOSED
}

// ============================================
// ANALYTICS — CHANGE EVENTS
// ============================================

model ChangeEvent {
  id           String          @id @default(cuid())
  accountId    String
  eventType    ChangeEventType
  title        String
  description  String          @db.Text
  resourceId   String?
  resourceType String?
  region       String?
  initiatedBy  String?
  metadata     String?         @db.Text
  occurredAt   DateTime
  createdAt    DateTime        @default(now())

  account      CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, occurredAt])
  @@index([eventType])
  @@map("change_events")
}

enum ChangeEventType {
  RESOURCE_CREATED
  RESOURCE_MODIFIED
  RESOURCE_DELETED
  CONFIG_CHANGE
  SECURITY_POLICY_CHANGE
  COST_BUDGET_CHANGE
  ACCOUNT_CONNECTED
  ACCOUNT_DISCONNECTED
}

// ============================================
// SERVICENOW INTEGRATION
// ============================================

model ServiceNowConfig {
  id          String             @id @default(cuid())
  userId      String             @unique
  instanceUrl String
  credentials String             @db.Text
  syncEnabled Boolean            @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets     ServiceNowTicket[]

  @@map("servicenow_configs")
}

model ServiceNowTicket {
  id           String               @id @default(cuid())
  configId     String
  ticketNumber String
  sysId        String?
  type         ServiceNowTicketType
  title        String
  description  String               @db.Text
  severity     ServiceNowSeverity
  status       ServiceNowStatus
  assignee     String?
  cloudAccount String?
  resourceId   String?
  region       String?
  category     String?
  externalUrl  String?
  resolvedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  config       ServiceNowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, ticketNumber])
  @@index([configId, status])
  @@map("servicenow_tickets")
}

enum ServiceNowTicketType {
  INCIDENT
  PROBLEM
  CHANGE
  REQUEST
}

enum ServiceNowSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ServiceNowStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
  CANCELLED
}

// ============================================
// TAGS
// ============================================

model Tag {
  id            String   @id @default(cuid())
  key           String
  value         String
  accountId     String?
  resourceCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([accountId, key, value])
  @@index([accountId])
  @@map("tags")
}

// ============================================
// ALERT CENTER
// ============================================

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum AlertType {
  COST_SPIKE
  BUDGET_THRESHOLD
  SECURITY_VIOLATION
  RESOURCE_ANOMALY
  ACCOUNT_HEALTH
  IDLE_RESOURCE
  CREDENTIAL_EXPIRY
  POLICY_CHANGE
}

model Alert {
  id             String        @id @default(cuid())
  userId         String
  cloudAccountId String?
  provider       String?
  type           AlertType
  severity       AlertSeverity
  status         AlertStatus   @default(OPEN)
  title          String
  message        String        @db.Text
  resourceId     String?
  resourceName   String?
  resourceType   String?
  metricValue    Float?
  thresholdValue Float?
  changePercent  Float?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cloudAccount CloudAccount? @relation(fields: [cloudAccountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([cloudAccountId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("alerts")
}
