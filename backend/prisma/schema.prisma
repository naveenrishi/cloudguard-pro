generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String?
  role              Role     @default(USER)
  mfaEnabled        Boolean  @default(false)
  mfaSecret         String?
  emailVerified     Boolean  @default(false)
  emailVerifiedAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  cloudAccounts     CloudAccount[]
  nukeRetentions    NukeRetention[]
  nukeRuns          NukeRun[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  VIEWER
}

// ============================================
// CLOUD ACCOUNTS
// ============================================

model CloudAccount {
  id            String        @id @default(cuid())
  userId        String
  provider      CloudProvider
  accountName   String
  accountId     String        // AWS Account ID / Azure Subscription ID / GCP Project ID
  region        String?       // Primary region
  credentials   String?       @db.Text  // Encrypted JSON with all credentials
  status        AccountStatus @default(ACTIVE)
  lastSyncAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources      Resource[]
  costData       CostData[]
  securityFindings SecurityFinding[]
  nukeConfig     NukeConfig?
  nukeRetentions NukeRetention[]

  @@unique([userId, provider, accountId])
  @@map("cloud_accounts")
}

enum CloudProvider {
  AWS
  AZURE
  GCP
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

// ============================================
// RESOURCES
// ============================================

model Resource {
  id            String   @id @default(cuid())
  accountId     String
  resourceId    String   // Cloud provider resource ID
  resourceType  String   // EC2, RDS, S3, VM, StorageAccount, etc.
  resourceName  String
  region        String
  metadata      String   @db.Text // JSON with all resource details
  status        String
  tags          String?  @db.Text // JSON
  costPerMonth  Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  account       CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metrics       ResourceMetric[]
  nukeRetentions NukeRetention[]

  @@unique([accountId, resourceId])
  @@index([accountId, resourceType])
  @@index([resourceType])
  @@map("resources")
}

// ============================================
// RESOURCE METRICS
// ============================================

model ResourceMetric {
  id            String   @id @default(cuid())
  resourceId    String
  metricName    String   // CPUUtilization, NetworkIn, DiskReadOps, etc.
  metricValue   Float
  unit          String
  timestamp     DateTime
  createdAt     DateTime @default(now())

  // Relations
  resource      Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, metricName, timestamp])
  @@map("resource_metrics")
}

// ============================================
// COST DATA
// ============================================

model CostData {
  id            String   @id @default(cuid())
  accountId     String
  date          DateTime
  service       String
  cost          Float
  currency      String   @default("USD")
  usage         Float?
  usageUnit     String?
  region        String?
  createdAt     DateTime @default(now())

  // Relations
  account       CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date, service, region])
  @@index([accountId, date])
  @@map("cost_data")
}

// ============================================
// SECURITY FINDINGS
// ============================================

model SecurityFinding {
  id            String   @id @default(cuid())
  accountId     String
  findingId     String   // Provider-specific finding ID
  severity      Severity
  title         String
  description   String   @db.Text
  resourceType  String
  resourceId    String?
  region        String?
  status        FindingStatus @default(ACTIVE)
  remediationSteps String? @db.Text
  detectedAt    DateTime
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  account       CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, findingId])
  @@index([accountId, severity, status])
  @@map("security_findings")
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  ACTIVE
  RESOLVED
  SUPPRESSED
  IN_PROGRESS
}

// ============================================
// OPTIMIZATION RECOMMENDATIONS
// ============================================

model Recommendation {
  id            String   @id @default(cuid())
  accountId     String?
  resourceId    String?
  category      RecommendationCategory
  title         String
  description   String   @db.Text
  impact        Impact
  savings       Float?   // Monthly savings in USD
  effort        Effort
  status        RecommendationStatus @default(OPEN)
  implementationSteps String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId, status, impact])
  @@map("recommendations")
}

enum RecommendationCategory {
  COST
  PERFORMANCE
  SECURITY
  RELIABILITY
  SUSTAINABILITY
}

enum Impact {
  HIGH
  MEDIUM
  LOW
}

enum Effort {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

// ============================================
// NUKE AUTOMATION
// ============================================

model NukeConfig {
  id                String   @id @default(cuid())
  accountId         String   @unique
  mode              NukeMode @default(MANUAL)
  enabled           Boolean  @default(false)
  schedule          String?  // Cron expression or date
  nextRunAt         DateTime?
  notificationDays  Int      @default(5)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  account           CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  nukeRuns          NukeRun[]

  @@map("nuke_configs")
}

enum NukeMode {
  AUTOMATIC
  MANUAL
}

model NukeRetention {
  id                String   @id @default(cuid())
  accountId         String
  userId            String
  resourceId        String
  resourceType      String
  resourceName      String
  resourceRegion    String?
  retentionType     RetentionType
  expiresAt         DateTime?
  retainDays        Int?
  reason            String   @db.Text
  isApproved        Boolean  @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  status            RetentionStatus @default(PENDING)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  account           CloudAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource          Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([resourceId])
  @@map("nuke_retentions")
}

enum RetentionType {
  PERMANENT
  UNTIL_DATE
  DAYS
}

enum RetentionStatus {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
}

model NukeRun {
  id                String   @id @default(cuid())
  configId          String
  userId            String
  runType           RunType
  status            RunStatus @default(PENDING)
  totalResources    Int      @default(0)
  deletedResources  Int      @default(0)
  retainedResources Int      @default(0)
  failedResources   Int      @default(0)
  errorMessage      String?  @db.Text
  executionLog      String?  @db.Text
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int?     // Duration in seconds
  createdAt         DateTime @default(now())

  // Relations
  config            NukeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([configId, createdAt])
  @@map("nuke_runs")
}

enum RunType {
  DRY_RUN
  LIVE
  SCHEDULED
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id            String   @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  message       String   @db.Text
  priority      Priority @default(NORMAL)
  isRead        Boolean  @default(false)
  actionUrl     String?
  metadata      String?  @db.Text // JSON
  createdAt     DateTime @default(now())

  // Relations
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

enum NotificationType {
  COST_ALERT
  SECURITY_ALERT
  NUKE_SCHEDULED
  NUKE_COMPLETED
  RETENTION_APPROVED
  RETENTION_REJECTED
  SYNC_COMPLETED
  SYNC_FAILED
  ACCOUNT_CONNECTED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String
  entityType    String
  entityId      String?
  changes       String?  @db.Text // JSON with before/after
  ipAddress     String?
  userAgent     String?
  status        String   // success, failure
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())

  // Relations
  user          User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================
// MIGRATION DATA
// ============================================

model MigrationAnalysis {
  id                String   @id @default(cuid())
  sourceAccountId   String?
  targetProvider    CloudProvider
  workloadType      String
  currentCost       Float
  targetCost        Float
  savingsPercent    Float
  complexity        String
  timeline          String
  recommendations   String   @db.Text // JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("migration_analyses")
}

// ============================================
// BUDGETS & ALERTS
// ============================================

model Budget {
  id            String   @id @default(cuid())
  accountId     String?
  name          String
  amount        Float
  period        BudgetPeriod
  startDate     DateTime
  endDate       DateTime?
  alertThreshold Float   @default(80) // Alert at 80% of budget
  notifyOnExceed Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId])
  @@map("budgets")
}

enum BudgetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ============================================
// TAGS
// ============================================

model Tag {
  id            String   @id @default(cuid())
  key           String
  value         String
  accountId     String?
  resourceCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([accountId, key, value])
  @@index([accountId])
  @@map("tags")
}
